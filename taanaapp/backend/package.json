{
  "name": "tanacargo-backend",
  "version": "1.0.0",
  "description": "Secure Node.js backend for TanaCargo e-commerce platform with SQL Server",
  "main": "src/server.js",
  "type": "module",
"scripts": {
  "start": "node src/server.js",
  "dev": "nodemon --watch src --ignore uploads/ src/server.js",
  "test": "jest --coverage",
  "lint": "eslint src/",
  "db:init": "node src/database/init.js",
  "db:seed": "node src/database/seed.js"
},
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "mssql": "^11.0.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xss-clean": "^0.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "eslint": "^9.10.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "ecommerce",
    "nodejs",
    "express",
    "sqlserver",
    "mssql",
    "api"
  ],
  "license": "MIT"
